{
  "name": "@cybourgeoisie/openrouter-agent-coder",
  "version": "0.2.0",
  "publishConfig": {
    "access": "public"
  },
  "description": "OpenRouter Agent SDK library — async-iterable agent core with tool gating, hooks, and abort. Drop-in replacement for @anthropic-ai/claude-agent-sdk with OpenRouter routing.",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "license": "MIT",
  "author": "Cybourgeoisie",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Cybourgeoisie/openrouter-agent-coder.git"
  },
  "bugs": {
    "url": "https://github.com/Cybourgeoisie/openrouter-agent-coder/issues"
  },
  "homepage": "https://github.com/Cybourgeoisie/openrouter-agent-coder#readme",
  "keywords": [
    "openrouter",
    "agent",
    "agent-sdk",
    "claude",
    "anthropic",
    "llm",
    "ai",
    "tool-use",
    "mcp"
  ],
  "engines": {
    "node": ">=20"
  },
  "files": [
    "dist",
    "!dist/**/*.test.*",
    "!dist/**/__tests__/**",
    "LICENSE",
    "README.md"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsx src/index.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:comparative": "vitest run --config vitest.comparative.config.ts",
    "test:comparative:live": "vitest run --config vitest.comparative-live.config.ts",
    "record:fixture": "tsx scripts/record-fixture.ts",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@openrouter/agent": "^0.3.2",
    "@openrouter/sdk": "^0.12.79",
    "zod": "^4.0.0"
  },
  "overrides": {
    "@openrouter/sdk": "^0.12.79"
  },
  "devDependencies": {
    "@anthropic-ai/claude-agent-sdk": "^0.3.150",
    "@anthropic-ai/sdk": "^0.98.0",
    "@eslint/js": "^10.0.1",
    "@types/node": "^22.19.19",
    "@vitest/coverage-v8": "^4.1.7",
    "eslint": "^10.4.0",
    "eslint-config-prettier": "^10.1.8",
    "prettier": "^3.4.2",
    "tsx": "^4.22.3",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.59.4",
    "vitest": "^4.1.7"
  }
}
