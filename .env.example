# Required
OPENROUTER_API_KEY=sk-or-v1-...

# OpenRouter API base URL (default: https://openrouter.ai/api/v1)
# Override to point at a local or staging instance.
# OPENROUTER_BASE_URL=http://localhost:3000/api/v1

# Model to use (default: ~anthropic/claude-sonnet-latest)
# OR_MODEL=anthropic/claude-sonnet-4

# Max agentic steps per prompt (default: 25)
# OR_MAX_STEPS=25

# Max cost in USD per prompt (default: 1.00)
# OR_MAX_COST=1.00

# Resume a previous session instead of starting a new one
# OR_SESSION_ID=sess_xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
