{
  "name": "multi-turn-with-tool",
  "steps": [
    { "type": "yield", "event": { "type": "turn.start", "turnNumber": 0, "timestamp": 1 } },
    { "type": "yield", "event": { "type": "response.output_text.delta", "delta": "thinking..." } },
    {
      "type": "yield",
      "event": {
        "type": "response.output_item.done",
        "outputIndex": 0,
        "sequenceNumber": 1,
        "item": {
          "type": "function_call",
          "callId": "call_a",
          "name": "echo",
          "arguments": "{\"value\":\"hello\"}"
        }
      }
    },
    {
      "type": "tool_execute",
      "toolName": "echo",
      "input": { "value": "hello" },
      "callId": "call_a"
    },
    { "type": "yield", "event": { "type": "turn.end", "turnNumber": 0, "timestamp": 2 } },
    { "type": "invoke_turn_end" },
    { "type": "yield", "event": { "type": "turn.start", "turnNumber": 1, "timestamp": 3 } },
    { "type": "yield", "event": { "type": "response.output_text.delta", "delta": "done" } },
    { "type": "yield", "event": { "type": "turn.end", "turnNumber": 1, "timestamp": 4 } }
  ],
  "response": {
    "id": "resp-multi",
    "model": "mock-model",
    "usage": { "cost": 0.002, "inputTokens": 20, "outputTokens": 8, "totalTokens": 28 },
    "output": []
  }
}
